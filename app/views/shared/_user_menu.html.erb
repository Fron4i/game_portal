<% if current_user %>
  <div class="relative"
       data-controller="user-menu"
       data-action="keydown.esc->user-menu#close click@window->user-menu#closeOnOutside">
    <button type="button"
            class="inline-flex items-center gap-2 h-9 px-3 rounded-md border border-border text-text hover:bg-surface-2 transition-colors duration-150 ease-out focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
            data-user-menu-target="trigger"
            data-action="click->user-menu#toggle"
            aria-haspopup="menu"
            aria-controls="user-menu-panel"
            aria-expanded="false">
      <span class="text-sm font-medium max-w-[10rem] truncate">
        <%= (current_user.respond_to?(:name) && current_user.name.presence) || current_user.email %>
      </span>
      <svg class="h-4 w-4 text-text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
        <path stroke-linecap="round" d="M6 9l6 6 6-6"/>
      </svg>
    </button>

    <div id="user-menu-panel"
         class="hidden absolute right-0 mt-2 min-w-44 rounded-md border border-border bg-surface-2 shadow-lg overflow-hidden"
         role="menu"
         data-user-menu-target="panel">
      <%= link_to t('iwebix.layout.user_menu.profile'), "/profile",
            role: "menuitem",
            class: "block px-4 py-2 text-sm text-text hover:bg-surface-3 focus:outline-none focus:bg-surface-3" %>
      <%= button_to t('iwebix.layout.user_menu.sign_out'), "/users/sign_out",
            method: :delete,
            class: "w-full text-left px-4 py-2 text-sm text-text hover:bg-surface-3 focus:outline-none focus:bg-surface-3",
            form: { role: "none" },
            data: { turbo_method: :delete } %>
    </div>
  </div>
<% else %>
  <%= link_to t('iwebix.layout.sign_in'), "/users/sign_in",
        class: "inline-flex items-center justify-center h-9 px-4 rounded-md text-sm font-medium bg-brand text-white hover:bg-violet-400 transition-colors duration-150 ease-out focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-surface" %>
<% end %>
