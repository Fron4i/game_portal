<% resource = local_assigns[:resource] %>
<% if resource && resource.errors.any? %>
  <div class="rounded-md border px-4 py-3 text-sm bg-danger/10 text-danger border-danger/30" role="alert">
    <p class="font-medium mb-1">
      <%= t("iwebix.auth.errors_title", count: resource.errors.count) %>
    </p>
    <ul class="list-disc list-inside space-y-0.5">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
