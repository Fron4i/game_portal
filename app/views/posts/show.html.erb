<% content_for(:title, @post.title) %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 space-y-8">
  <%= render "shared/breadcrumbs", crumbs: [
        [t("iwebix.layout.nav.games"),  games_path],
        [@post.game.title,              game_path(@post.game)],
        [@post.title,                   nil]
      ] %>

  <%= render "shared/button",
        label: "← #{t('iwebix.layout.back')}",
        variant: :secondary, size: :sm, as: :link_to,
        href: back_path %>

  <article class="space-y-6">
    <header class="space-y-4">
      <div class="flex flex-wrap items-center gap-3">
        <%= render "shared/badge",
              variant: @post.kind.to_sym,
              label: t("iwebix.posts.card.kinds.#{@post.kind}") %>
        <% if @post.published_at %>
          <span class="text-xs font-mono text-text-muted">
            <%= l @post.published_at.to_date, format: :short_date %>
          </span>
        <% end %>
      </div>

      <h1 class="font-display text-3xl md:text-4xl font-semibold leading-tight">
        <%= @post.title %>
      </h1>

      <p class="text-sm text-text-muted">
        <%= t("iwebix.posts.show.by",
              author: (@post.author&.name.presence || @post.author&.email || t("iwebix.posts.show.deleted_author"))) %>
        ·
        <%= link_to @post.game.title, game_path(@post.game),
              class: "text-accent hover:underline focus:outline-none focus-visible:underline" %>
      </p>
    </header>

    <div class="iwebix-prose text-text leading-relaxed">
      <%= @post.body %>
    </div>

    <div class="pt-4 border-t border-border">
      <%= render "likes/button",
            likeable: @post,
            data_test: "post-like",
            count_test_id: "post-likes-count" %>
    </div>
  </article>

  <section class="space-y-6">
    <%= turbo_frame_tag dom_id(@post, :comments) do %>
      <h2 class="font-display text-2xl font-semibold border-b border-border pb-2">
        <%= t("iwebix.comments.title", count: @post.comments.size) %>
      </h2>

      <div class="space-y-6">
        <%= render "comments/form", post: @post, comment: Comment.new %>
        <%= render "comments/list", comments: @comments, pagy: @pagy %>
      </div>
    <% end %>
  </section>
</div>
