<% content_for(:title, t("iwebix.auth.edit_profile.title")) %>

<div class="max-w-md mx-auto px-4 py-12 space-y-6">
  <%= render "shared/breadcrumbs", crumbs: [
        [t("iwebix.profile.title"),             profile_path],
        [t("iwebix.auth.edit_profile.title"),   nil]
      ] %>

  <header class="space-y-1">
    <h1 class="font-display text-3xl font-semibold"><%= t("iwebix.auth.edit_profile.title") %></h1>
  </header>


  <%= render layout: "shared/card" do %>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
                 html: { method: :put, class: "space-y-4" }) do |f| %>
      <%= render "shared/form_errors", resource: resource %>

      <%= render "shared/input",
            id: "user_name", name: "user[name]", type: "text",
            value: resource.name, label: t("iwebix.auth.fields.name") %>

      <%= render "shared/input",
            id: "user_email", name: "user[email]", type: "email",
            value: resource.email, label: t("iwebix.auth.fields.email") %>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <p class="text-sm text-warning">
          <%= t("iwebix.auth.edit_profile.pending_email", email: resource.unconfirmed_email) %>
        </p>
      <% end %>

      <%= render "shared/input",
            id: "user_password", name: "user[password]", type: "password",
            label: t("iwebix.auth.edit_profile.new_password"),
            hint: t("iwebix.auth.fields.password_hint",
                    minimum: @minimum_password_length || Devise.password_length.min) %>

      <%= render "shared/input",
            id: "user_password_confirmation", name: "user[password_confirmation]", type: "password",
            label: t("iwebix.auth.edit_profile.new_password_confirmation") %>

      <%= render "shared/input",
            id: "user_current_password", name: "user[current_password]", type: "password",
            label: t("iwebix.auth.edit_profile.current_password"),
            hint: t("iwebix.auth.edit_profile.current_password_hint") %>

      <div class="flex flex-col sm:flex-row-reverse sm:justify-start gap-3">
        <%= render "shared/button",
              label: t("iwebix.auth.edit_profile.submit"),
              variant: :primary, size: :md, as: :button, type: "submit",
              class: "w-full sm:w-auto" %>
        <%= render "shared/button",
              label: t("iwebix.layout.cancel"),
              variant: :secondary, size: :md, as: :link_to,
              href: profile_path,
              class: "w-full sm:w-auto" %>
      </div>
    <% end %>
  <% end %>

  <%= render layout: "shared/card" do %>
    <div class="space-y-3">
      <h2 class="font-display text-xl font-semibold text-danger"><%= t("iwebix.auth.edit_profile.delete_title") %></h2>
      <p class="text-text-muted text-sm"><%= t("iwebix.auth.edit_profile.delete_warning") %></p>
      <%= button_to t("iwebix.auth.edit_profile.delete_button"),
            registration_path(resource_name),
            method: :delete,
            data: { turbo_confirm: t("iwebix.auth.edit_profile.delete_confirm") },
            class: "inline-flex items-center justify-center gap-2 font-medium rounded-md transition-colors duration-150 ease-out h-10 px-4 text-base bg-danger text-white hover:bg-red-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-surface" %>
    </div>
  <% end %>
</div>
