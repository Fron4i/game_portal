<% content_for(:title, t("iwebix.auth.sign_up.title")) %>

<div class="max-w-md mx-auto px-4 py-12 space-y-6">
  <header class="space-y-1">
    <h1 class="font-display text-3xl font-semibold"><%= t("iwebix.auth.sign_up.title") %></h1>
    <p class="text-text-muted text-sm"><%= t("iwebix.auth.sign_up.subtitle") %></p>
  </header>


  <%= render layout: "shared/card" do %>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <%= render "shared/form_errors", resource: resource %>

      <%= render "shared/input",
            id: "user_name", name: "user[name]", type: "text",
            value: resource.name, label: t("iwebix.auth.fields.name"),
            hint: t("iwebix.auth.fields.name_hint") %>

      <%= render "shared/input",
            id: "user_email", name: "user[email]", type: "email",
            value: resource.email, label: t("iwebix.auth.fields.email"),
            placeholder: t("iwebix.auth.fields.email_placeholder") %>

      <%= render "shared/input",
            id: "user_password", name: "user[password]", type: "password",
            label: t("iwebix.auth.fields.password"),
            hint: t("iwebix.auth.fields.password_hint",
                    minimum: @minimum_password_length || Devise.password_length.min) %>

      <%= render "shared/input",
            id: "user_password_confirmation", name: "user[password_confirmation]", type: "password",
            label: t("iwebix.auth.fields.password_confirmation") %>

      <%= render "shared/button",
            label: t("iwebix.auth.sign_up.submit"),
            variant: :primary, size: :md, as: :button, type: "submit",
            class: "w-full" %>
    <% end %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
