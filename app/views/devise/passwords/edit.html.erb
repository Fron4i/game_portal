<% content_for(:title, t("iwebix.auth.reset_password.title")) %>

<div class="max-w-md mx-auto px-4 py-12 space-y-6">
  <header class="space-y-1">
    <h1 class="font-display text-3xl font-semibold"><%= t("iwebix.auth.reset_password.title") %></h1>
    <p class="text-text-muted text-sm"><%= t("iwebix.auth.reset_password.subtitle") %></p>
  </header>


  <%= render layout: "shared/card" do %>
    <%= form_for(resource, as: resource_name, url: password_path(resource_name),
                 html: { method: :put, class: "space-y-4" }) do |f| %>
      <%= render "shared/form_errors", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <%= render "shared/input",
            id: "user_password", name: "user[password]", type: "password",
            label: t("iwebix.auth.reset_password.new_password"),
            hint: t("iwebix.auth.fields.password_hint",
                    minimum: @minimum_password_length || Devise.password_length.min) %>

      <%= render "shared/input",
            id: "user_password_confirmation", name: "user[password_confirmation]", type: "password",
            label: t("iwebix.auth.reset_password.new_password_confirmation") %>

      <%= render "shared/button",
            label: t("iwebix.auth.reset_password.submit"),
            variant: :primary, size: :md, as: :button, type: "submit",
            class: "w-full" %>
    <% end %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
