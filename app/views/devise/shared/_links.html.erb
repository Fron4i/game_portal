<nav class="flex flex-col gap-2 text-sm text-text-muted">
  <% if controller_name != "sessions" %>
    <%= link_to t("iwebix.auth.links.sign_in"), new_session_path(resource_name),
          class: "hover:text-text focus:outline-none focus-visible:underline" %>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <%= link_to t("iwebix.auth.links.sign_up"), new_registration_path(resource_name),
          class: "hover:text-text focus:outline-none focus-visible:underline" %>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <%= link_to t("iwebix.auth.links.forgot_password"), new_password_path(resource_name),
          class: "hover:text-text focus:outline-none focus-visible:underline" %>
  <% end %>

  <% if devise_mapping.confirmable? && controller_name != "confirmations" %>
    <%= link_to t("iwebix.auth.links.resend_confirmation"), new_confirmation_path(resource_name),
          class: "hover:text-text focus:outline-none focus-visible:underline" %>
  <% end %>
</nav>
