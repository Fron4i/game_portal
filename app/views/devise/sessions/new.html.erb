<% content_for(:title, t("iwebix.auth.sign_in.title")) %>

<div class="max-w-md mx-auto px-4 py-12 space-y-6">
  <header class="space-y-1">
    <h1 class="font-display text-3xl font-semibold"><%= t("iwebix.auth.sign_in.title") %></h1>
    <p class="text-text-muted text-sm"><%= t("iwebix.auth.sign_in.subtitle") %></p>
  </header>


  <%= render layout: "shared/card" do %>
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
      <%= render "shared/form_errors", resource: resource %>

      <%= render "shared/input",
            id: "user_email", name: "user[email]", type: "email",
            value: resource.email, label: t("iwebix.auth.fields.email"),
            placeholder: t("iwebix.auth.fields.email_placeholder") %>

      <%= render "shared/input",
            id: "user_password", name: "user[password]", type: "password",
            label: t("iwebix.auth.fields.password") %>

      <% if devise_mapping.rememberable? %>
        <label class="inline-flex items-center gap-2 text-sm text-text">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-border bg-surface-2 text-brand focus:ring-brand focus:ring-offset-surface" %>
          <%= t("iwebix.auth.sign_in.remember_me") %>
        </label>
      <% end %>

      <%= render "shared/button",
            label: t("iwebix.auth.sign_in.submit"),
            variant: :primary, size: :md, as: :button, type: "submit",
            class: "w-full",
            data: { turbo_submits_with: t("iwebix.auth.sign_in.submitting") } %>
    <% end %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
