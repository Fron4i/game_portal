<h1>Профиль</h1>

<section>
  <h2>Мои комментарии</h2>
  <ul>
    <% @comments.each do |comment| %>
      <li><%= link_to comment.post.title, post_path(comment.post) %>: <%= comment.body %></li>
    <% end %>
  </ul>
  <%= pagy_nav(@pagy) if @pagy.pages > 1 %>
</section>

<section>
  <h2>Мои подписки</h2>
  <ul>
    <% @subscribed_games.each do |game| %>
      <li><%= link_to game.title, game_path(game) %></li>
    <% end %>
  </ul>
</section>
