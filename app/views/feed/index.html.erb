<% content_for(:title, t("iwebix.feed.title")) %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 space-y-8">
  <header class="space-y-2">
    <h1 class="font-display text-3xl md:text-4xl font-semibold"><%= t("iwebix.feed.title") %></h1>
    <p class="text-text-muted"><%= t("iwebix.feed.subtitle") %></p>
  </header>

  <% if @posts.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @posts.each do |post| %>
        <%= render "posts/card", post: post %>
      <% end %>
    </div>

    <%= render "shared/pagination", pagy: @pagy %>
  <% else %>
    <div class="rounded-2xl border border-border bg-surface-2 px-6 py-16 text-center space-y-4">
      <p class="font-display text-2xl font-semibold"><%= t("iwebix.feed.empty.title") %></p>
      <p class="text-text-muted max-w-md mx-auto"><%= t("iwebix.feed.empty.subtitle") %></p>
      <%= render "shared/button",
            label: t("iwebix.feed.empty.cta"),
            variant: :primary, size: :md, as: :link_to,
            href: games_path %>
    </div>
  <% end %>
</div>
